alert tcp any 1024:80 -> any 80 (msg:"inverted range"; sid:1;)
alert tcp any any -> any 70000:80000 (msg:"range bounds out of range"; sid:2;)
alert tcp any any -> any 0:80 (msg:"zero lower bound"; sid:3;)
alert tcp any any -> any [80,80] (msg:"duplicate port entry"; sid:4;)
alert tcp any any -> any [1:1024,443:8080,443:8080] (msg:"duplicate range entry"; sid:5;)
alert tcp any any -> any [1:65535,80] (msg:"subsumed entry warning only"; sid:6;)
alert tcp any any -> any [!80,!443] (msg:"all negated warning only"; sid:7;)
alert tcp any any -> [10.0.0.1,10.0.0.1] 80 (msg:"duplicate address entry"; sid:8;)
alert tcp any any -> [10.0.0.1,999.0.0.1,10.0.0.0/33] 80 (msg:"two bad elements one list"; sid:9;)
